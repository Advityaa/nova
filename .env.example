# ---------------------------------------------------------------------------
# Nova Events — environment variables
# Copy this file to `.env.local` and fill in the values. NEVER commit secrets.
# ---------------------------------------------------------------------------

# Neon Postgres (via the Vercel Marketplace → Neon integration). The integration
# auto-injects DATABASE_URL on deploys; for local dev copy it from the Neon
# integration's ".env.local" tab in Vercel. The app reads DATABASE_URL (with a
# POSTGRES_URL fallback for back-compat).
DATABASE_URL=
# Direct (unpooled) URL — optional; used as a fallback for one-off scripts.
DATABASE_URL_UNPOOLED=

# Vercel Blob — object storage for event-images / gallery uploads (dashboard
# stage). Create a Blob store in Vercel and paste its token here.
BLOB_READ_WRITE_TOKEN=

# Payment provider selector. Only 'mock' is implemented (no real charges).
# A real gateway is added later as one file + this value.
PAYMENT_PROVIDER=mock

# ---------------------------------------------------------------------------
# Auth.js (NextAuth v5) — admin login
# ---------------------------------------------------------------------------
# Session signing secret. Generate one with:  openssl rand -base64 32
AUTH_SECRET=

# One-time owner seed (used only by `npm run user:seed-owner`, read from
# .env.local — never commit real values). After seeding you can delete these.
OWNER_EMAIL=owner@novaevents.sh
OWNER_PASSWORD=change-me-strong-password
